# ====================
# Unity .gitattributes
# ====================

# Set default behavior to automatically normalize line endings
* text=auto

# Unity scripts (C#) - text files with diff
*.cs text diff=csharp
*.cginc text
*.shader text
*.hlsl text
*.hlslinc text

# Unity project files
*.unity text diff=unity
*.prefab text diff=unity
*.asset text diff=unity
*.meta text
*.mat text
*.controller text
*.anim text
*.overrideController text
*.mask text
*.renderTexture text
*.spriteatlas text
*.terrainlayer text
*.signal text

# Unity settings
*.playable text
*.physicMaterial text
*.physicsMaterial2D text
*.preset text

# Text serialization format
*.scenetemplate text

# JSON / XML
*.json text
*.xml text
*.xsl text
*.xsd text

# Documentation
*.md text
*.txt text

# Images - binary
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
